                            if head and t and la and ra and ll and rl then
                                local hV, tV, laV, raV, llV, rlV = Camera:WorldToViewportPoint(head.Position), Camera:WorldToViewportPoint(t.Position), Camera:WorldToViewportPoint(la.Position), Camera:WorldToViewportPoint(ra.Position), Camera:WorldToViewportPoint(ll.Position), Camera:WorldToViewportPoint(rl.Position)
                                if hV.Z > 0 and tV.Z > 0 and laV.Z > 0 and raV.Z > 0 and llV.Z > 0 and rlV.Z > 0 then
                                    sk.H2T.From, sk.H2T.To = Vector2new(hV.X, hV.Y), Vector2new(tV.X, tV.Y)
                                    sk.T2LA.From, sk.T2LA.To = Vector2new(tV.X, tV.Y), Vector2new(laV.X, laV.Y)
