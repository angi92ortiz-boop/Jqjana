    local function LimpiarESP(p)
        local cache = CacheESP[p]
        if cache then
            cache.Box.Visible = false; cache.Name.Visible = false; cache.Dist.Visible = false
            cache.HBarO.Visible = false; cache.HBar.Visible = false; cache.Hand.Visible = false; cache.Inv.Visible = false
            for _, l in pairs(cache.Skel) do l.Visible = false end
        end
    end

    local function EliminarCompletamenteESP(p)
        if CacheESP[p] then
            local cache = CacheESP[p]
            pcall(function() cache.Box:Remove() cache.Name:Remove() cache.Dist:Remove() cache.HBarO:Remove() cache.HBar:Remove() cache.Hand:Remove() cache.Inv:Remove() end)
            for _, l in pairs(cache.Skel) do pcall(function() l:Remove() end) end
            CacheESP[p] = nil
        end
        itemCache[p] = nil
    end
    table.insert(connections, Players.PlayerRemoving:Connect(EliminarCompletamenteESP))

    local function GetItems(p, full)
        if not p or not p.Character then return full and "Vacío" or "Ninguno" end
        local cache = itemCache[p]
        if not cache or tick() - cache.LastUpdate > 0.6 then
            local c, b, l = p.Character, p:FindFirstChild("Backpack"), {}
            if c then for _, v in ipairs(c:GetChildren()) do if v:IsA("Tool") then table.insert(l, v) end end end
            if b and full then for _, v in ipairs(b:GetChildren()) do if v:IsA("Tool") then table.insert(l, v) end end end
            local handStr = #l > 0 and l[1].Name or "Ninguno"
            local invStr = ""
            if #l == 0 then invStr = "Vacío" else for i = 1, #l do invStr = invStr .. "• " .. l[i].Name .. "\n" end end
            itemCache[p] = { LastUpdate = tick(), Hand = handStr, Inv = invStr }
            cache = itemCache[p]
        end
        return full and cache.Inv or cache.Hand
    end

